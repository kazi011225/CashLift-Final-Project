# Copy this file to .env and fill in your real values.
# .env is gitignored — .env.example is NOT (it has no real secrets, just shows the shape).

MONGODB_URI=mongodb+srv://username:password@yourcluster.mongodb.net/cashlift?retryWrites=true&w=majority
SESSION_SECRET=replace_this_with_any_long_random_string
GEMINI_API_KEY=your_gemini_api_key_here
PORT=3000
